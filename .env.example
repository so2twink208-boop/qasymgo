# .env.example — скопируйте в .env и заполните

# Токен бота от @BotFather
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram ID администраторов через запятую (без пробелов)
# Узнать свой ID можно у @userinfobot
ADMIN_IDS=123456789,987654321

# Путь к файлу базы данных (можно не менять)
DB_PATH=qasymgo.db
